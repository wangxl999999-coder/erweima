.input-section {
  margin-bottom: 30rpx;
}

.content-input {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  background-color: #f5f7fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.upload-section {
  padding: 40rpx 0;
}

.upload-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 200rpx;
  background-color: #f5f7fa;
  border: 2rpx dashed #cbd5e1;
  border-radius: 16rpx;
}

.upload-btn::after {
  border: none;
}

.upload-icon {
  font-size: 64rpx;
  color: #94a3b8;
  margin-bottom: 16rpx;
}

.upload-btn text {
  color: #64748b;
  font-size: 28rpx;
}

.qrcode-container {
  background-color: #f8fafc;
  border: 2rpx solid #e2e8f0;
}

.btn-primary, .btn-secondary, .upload-btn {
  width: 100%;
  margin-top: 20rpx;
}

.btn-primary::after, .btn-secondary::after {
  border: none;
}
