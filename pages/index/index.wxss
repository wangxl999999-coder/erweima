.input-section {
  margin-bottom: 30rpx;
}

.content-input {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  background-color: #f5f7fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.upload-tips {
  margin-bottom: 20rpx;
  padding: 20rpx;
  background-color: #eff6ff;
  border-radius: 12rpx;
  border-left: 6rpx solid #3b82f6;
}

.tips-text {
  font-size: 26rpx;
  color: #1d4ed8;
  line-height: 1.6;
}

.upload-section {
  padding: 30rpx 0;
}

.upload-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 180rpx;
  background-color: #f5f7fa;
  border: 2rpx dashed #cbd5e1;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.upload-btn::after {
  border: none;
}

.upload-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.upload-btn text {
  color: #3b82f6;
  font-size: 30rpx;
  font-weight: 500;
}

.upload-hint {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background-color: #fefce8;
  border-radius: 8rpx;
}

.hint-text {
  font-size: 24rpx;
  color: #854d0e;
  line-height: 1.5;
}

.qrcode-container {
  background-color: #f8fafc;
  border: 2rpx solid #e2e8f0;
}

.btn-primary, .btn-secondary, .upload-btn {
  width: 100%;
  margin-top: 20rpx;
}

.btn-primary::after, .btn-secondary::after {
  border: none;
}
