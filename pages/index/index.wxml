<view class="container">
  <view class="card">
    <view class="section-title">生成二维码</view>
    <view class="input-section">
      <textarea
        class="content-input"
        placeholder="请输入要生成二维码的内容"
        value="{{content}}"
        bindinput="onInputChange"
        maxlength="500"
        auto-height
      />
    </view>
    <button class="btn-primary" bindtap="generateQRCode">生成二维码</button>
  </view>

  <view class="card">
    <view class="section-title">上传二维码</view>
    <view class="upload-tips">
      <text class="tips-text">点击下方按钮，可选择从相册识别二维码或拍照识别</text>
    </view>
    <view class="upload-section flex-center">
      <button class="btn-secondary upload-btn" bindtap="showUploadOptions">
        <text class="upload-icon">📷</text>
        <text>识别二维码</text>
      </button>
    </view>
    <view class="upload-hint">
      <text class="hint-text">提示：在识别界面点击右上角菜单可选择相册图片</text>
    </view>
  </view>

  <view class="card" wx:if="{{isGenerated}}">
    <view class="section-title">二维码预览</view>
    <view class="qrcode-container">
      <canvas
        type="2d"
        id="qrcodeCanvas"
        class="qrcode-image"
        style="width: 400rpx; height: 400rpx;"
      />
    </view>
    <button class="btn-primary" bindtap="goToBeautify">开始美化</button>
  </view>
</view>
